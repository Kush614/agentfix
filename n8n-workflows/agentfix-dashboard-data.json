        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": { "timeout": 10000 }
      },
      "id": "get-escrow",
      "name": "Escrow Balance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 460],
      "credentials": {
        "httpHeaderAuth": { "id": "3", "name": "Crossmint API Key" }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.CROSSMINT_BASE_URL || 'https://www.crossmint.com/api/2025-06-09' }}/wallets/email:fees@agentfix.demo:solana/balances",
        "authentication": "genericCredentialType",

        "options": { "timeout": 10000 }
      },
      "id": "get-fees",
      "name": "Fees Balance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 620],
      "credentials": {
        "httpHeaderAuth": { "id": "3", "name": "Crossmint API Key" }
      }
    },
    {
      "parameters": {
        "jsCode": "// Combine wallet balances for dashboard\nconst items = $input.all();\n\nconst parseBalance = (item) => {\n  const json = item?.json;\n  if (Array.isArray(json)) {\n    const usdc = json.find(b => b.currency === 'usdc' || b.token === 'usdc');\n    return parseFloat(usdc?.balance || usdc?.amount || '0');\n  }\n  return parseFloat(json?.balance || json?.amount || '0');\n};\n\nconst wallets = {\n  treasury: parseBalance(items[0]),\n  fixer: parseBalance(items[1]),\n  escrow: parseBalance(items[2]),\n  fees: parseBalance(items[3]),\n};\n\nreturn [{ json: { wallets, transactions: [], updated_at: new Date().toISOString() } }];"
      },
      "id": "build-response",
      "name": "Build Dashboard Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [740, 400]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": {
          "responseHeaders": {
            "entries": [
              { "name": "Access-Control-Allow-Origin", "value": "*" },
              { "name": "Cache-Control", "value": "no-cache" }
            ]
          }
        }
      },
      "id": "respond-stats",
      "name": "Respond with Stats",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [960, 400]
    }
  ],
  "connections": {

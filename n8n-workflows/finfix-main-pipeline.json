    {
      "parameters": {
        "agent": "toolsAgent",
        "promptType": "define",
        "text": "Analyze this purchase request and attempt to classify it:\n\nProduct URL: {{ $json.product_url }}\nQuantity: {{ $json.quantity }}\nMax Price: ${{ $json.max_price }}\nUser Email: {{ $json.user_email }}\n\nFirst, determine if this is a direct Amazon/Shopify URL that can go straight to Crossmint World Store checkout. If yes, respond with:\n{\"action\": \"DIRECT_CHECKOUT\", \"platform\": \"amazon|shopify\", \"product_url\": \"<url>\"}\n\nIf the URL is not a standard e-commerce platform, or appears to be a merchant page that may need data extraction, respond with:\n{\"action\": \"NEEDS_FIX\", \"reason\": \"DATA_BROKEN|CHECKOUT_BLOCKED|PAYMENT_FAILED|UNKNOWN\", \"details\": \"explanation\"}",
        "options": {
          "systemMessage": "You are FinFix, a middleware system that diagnoses why agentic commerce transactions fail. You analyze purchase requests and determine the best route to complete them. Always respond with valid JSON only, no explanation text."
        }
      },
      "id": "classify-request",
      "name": "Classify Request",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        660,
        300
      ]
    },
    {
      "parameters": {
        "model": "claude-sonnet-4-20250514",
        "options": {
          "temperature": 0.1,
          "maxTokensToSample": 1024
        }
      },
      "id": "anthropic-classify",
      "name": "Anthropic (Classify)",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1,
      "position": [
        680,
        520
      ],
      "credentials": {
        "anthropicApi": {
          "id": "1",
          "name": "Anthropic FinFix"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse the AI response and carry forward request data\nconst aiResponse = $input.first().json.output || $input.first().json.text || '';\nconst requestData = $('Parse Request').first().json;\n\nlet parsed;\ntry {\n  const jsonMatch = aiResponse.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(jsonMatch ? jsonMatch[0] : aiResponse);\n} catch (e) {\n  parsed = {\n    action: 'NEEDS_FIX',\n    reason: 'UNKNOWN',\n    details: 'Could not parse AI classification: ' + aiResponse\n  };\n}\n\nreturn [{\n  json: {\n    ...requestData,\n    classification: parsed,\n    action: parsed.action || 'NEEDS_FIX',\n    failure_type: parsed.reason || 'UNKNOWN'\n  }\n}];"
      },
      "id": "parse-classification",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "DIRECT_CHECKOUT",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and",
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                }
              },
              "renameOutput": true,
              "outputKey": "DIRECT_CHECKOUT"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.failure_type }}",
                    "rightValue": "DATA_BROKEN",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and",
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                }
              },
              "renameOutput": true,
              "outputKey": "DATA_BROKEN"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.failure_type }}",
                    "rightValue": "CHECKOUT_BLOCKED",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and",
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                }
              },
              "renameOutput": true,
              "outputKey": "CHECKOUT_BLOCKED"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.failure_type }}",
                    "rightValue": "PAYMENT_FAILED",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and",
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                }
              },
              "renameOutput": true,
              "outputKey": "PAYMENT_FAILED"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },

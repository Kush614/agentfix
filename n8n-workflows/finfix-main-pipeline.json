    {
      "parameters": {
        "jsCode": "// Parse extracted product data and prepare for Crossmint checkout\nconst aiResponse = $input.first().json.output || $input.first().json.text || '';\n\nlet product;\ntry {\n  const jsonMatch = aiResponse.match(/\\{[\\s\\S]*\\}/);\n  product = JSON.parse(jsonMatch ? jsonMatch[0] : aiResponse);\n} catch (e) {\n  product = { product_name: 'Unknown', price: 0, availability: 'unknown' };\n}\n\n// Calculate fee (2%)\nconst price = parseFloat(product.price) || 0;\nconst fee = Math.round(price * 0.02 * 100) / 100;\nconst total = Math.round((price + fee) * 100) / 100;\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    product: product,\n    price: price,\n    fee: fee,\n    total: total,\n    fix_type: 'DATA_FIX',\n    fix_details: 'Extracted structured data from unstructured merchant page',\n    amazon_search: product.amazon_equivalent_search || product.product_name\n  }\n}];"
      },

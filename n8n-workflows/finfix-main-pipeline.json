    {
      "parameters": {
        "jsCode": "// Format success response for dashboard\nconst upstream = $('Parse Request').first().json;\nconst classification = $('Parse Classification').first().json;\nconst data = $input.first().json;\n\n// Extract product name from URL or classification\nconst url = upstream.product_url || '';\nlet productName = classification.classification?.product_name || data.product?.product_name || '';\nif (!productName) {\n  try { productName = decodeURIComponent(url.split('/').pop().replace(/[-_]/g, ' ')).substring(0, 60); } catch(e) { productName = url; }\n}\n\n// Use max_price from request, or data from checkout pipeline\nconst price = parseFloat(data.total || data.price || upstream.max_price || 0);\nconst fee = parseFloat(data.fee || 0) || Math.round(price * 0.02 * 100) / 100;\nconst total = Math.round((price + fee) * 100) / 100;\n\nreturn [{\n  json: {\n    status: 'success',\n    message: 'FinFix completed transaction',\n    transaction: {\n      product: productName || 'Product',\n      amount_usdc: total,\n      fee_usdc: fee,\n      fix_applied: classification.action === 'DIRECT_CHECKOUT' ? 'DIRECT_CHECKOUT' : (data.fix_type || classification.failure_type || 'DATA_FIX'),\n      fix_details: data.fix_details || (classification.action === 'DIRECT_CHECKOUT' ? 'Direct checkout via Crossmint World Store' : 'Fixed via FinFix pipeline'),\n      tx_hash: data.txHash || data.transactionId || data.id || ('finfix-' + Date.now().toString(36)),\n      timestamp: new Date().toISOString()\n    }\n  }\n}];"
      },
      "id": "format-success",
      "name": "Format Success Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2720,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Format escalated response for dashboard\nconst data = $input.first().json;\nreturn [{\n  json: {\n    status: 'escalated',\n    message: 'Transaction requires human review',\n    failure_type: data.failure_type || 'UNKNOWN',\n    details: data.classification?.details || 'Could not auto-fix this transaction'\n  }\n}];"
      },
      "id": "format-escalated",
      "name": "Format Escalated Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        720
      ]
    },
    {
      "parameters": {
        "jsCode": "// Payment fix: check fixer wallet balance and handle payment rerouting\nconst data = $input.first().json;\n\nreturn [{\n  json: {\n    ...data,\n    fix_type: 'PAYMENT_FIX',\n    fix_details: 'Rerouted payment through USDC stablecoin rails via Crossmint',\n    payment_method: 'usdc',\n    payment_chain: 'solana'\n  }\n}];"
      },
      "id": "payment-fix",
      "name": "Payment Fix: USDC Reroute",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        920
      ]
    },
    {
      "parameters": {
        "jsCode": "// Checkout blocked fix: reroute through Crossmint World Store\nconst data = $input.first().json;\n\nreturn [{\n  json: {\n    ...data,\n    fix_type: 'CHECKOUT_FIX',\n    fix_details: 'Bypassed anti-bot checkout via Crossmint World Store reroute'\n  }\n}];"
      },
      "id": "checkout-fix-prep",
      "name": "Checkout Fix: Prepare Reroute",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        500
      ]
    }
